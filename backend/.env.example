# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/essassess

# Auth
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_REFRESH_SECRET_KEY=change-me-to-another-long-random-string
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# AI — Grading Module
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# File storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# CORS — comma-separated list of allowed origins
# Development: CORS_ORIGINS=http://localhost:3000
# Docker:      CORS_ORIGINS=http://localhost:3000,http://frontend:3000
CORS_ORIGINS=http://localhost:3000
